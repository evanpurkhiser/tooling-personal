{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@evanpurkhiser/tooling-personal",
  "version": "1.49.0",
  "description": "Evan Purkhiser's personal tooling",
  "license": "MIT",
  "author": "Evan Purkhiser",
  "repository": "https://github.com/evanpurkhiser/tooling-personal",
  "bin": {
    "pt": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.0.0"
    }
  },
  "scripts": {
    "build": "tsc && chmod +x ./dist/index.js",
    "start": "ts-node ./src/index.ts",
    "lint": "oxlint src/",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@octokit/graphql-schema": "^10.54.0",
    "@types/convict": "^6.1.3",
    "@types/git-url-parse": "^9.0.1",
    "@types/js-yaml": "^4.0.2",
    "@types/node": "^16.3.3",
    "@types/yargs": "^17.0.2",
    "chalk": "^4.1.1",
    "convict": "^6.2.4",
    "fast-merge-async-iterators": "^1.0.5",
    "git-url-parse": "^11.5.0",
    "graphql": "^15.5.1",
    "graphql-request": "^3.4.0",
    "js-yaml": "^4.1.0",
    "listr2": "^3.11.0",
    "open": "^8.2.1",
    "simple-git": "^2.41.1",
    "yargs": "^17.0.1"
  },
  "devDependencies": {
    "@evanpurkhiser/oxc-config": "^0.8.0",
    "@tsconfig/node16": "^1.0.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
